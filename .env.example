# ─── Database ────────────────────────────────────────────────────────────────
# Docker maps postgres to 5433 to avoid conflicts with local installs
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/aiedu

# ─── Redis ───────────────────────────────────────────────────────────────────
# Docker maps redis to 6380 to avoid conflicts with local installs
REDIS_URL=redis://localhost:6380

# ─── Auth (NextAuth v5) ───────────────────────────────────────────────────────
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# ─── Google Gemini (AI Studio — free tier) ────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-google-ai-studio-key
GEMINI_MODEL=gemini-2.0-flash

# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
