# Database — ports non-standard en dev local (voir docker-compose.yml)
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/aiedu
REDIS_URL=redis://localhost:6380

# Auth — NextAuth v5
AUTH_SECRET=change-me-in-production-min-32-chars
AUTH_URL=http://localhost:3000

# Google OAuth (créer sur console.cloud.google.com)
# Origines autorisées : http://localhost:3000
# URI de redirection : http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your_google_client_id_here
AUTH_GOOGLE_SECRET=your_google_client_secret_here

# Secret serveur-à-serveur pour POST /auth/oauth (générer avec openssl rand -hex 32)
AUTH_OAUTH_SECRET=change-me-server-to-server-secret

# Compatibilité v4 NextAuth (fallback dans l'API)
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# AI Provider
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

# App
NODE_ENV=development
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
